# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@srtanognog.com
RESEND_TO_EMAIL=srtanognog@gmail.com

# Cloudflare Turnstile Configuration (for Contact Form)
PUBLIC_CLOUDFLARE_TURNSTILE_SITEKEY=your_turnstile_site_key_here
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Cloudflare KV (REST API desde Cloud Run / Node)
# Crea un API Token con permiso "Account > Workers KV Storage > Edit"
# El namespace ID lo encuentras en Workers & Pages > KV > tu namespace
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id_here
# Opcional: prefijo para aislar las claves de este proyecto en un namespace compartido
# CLOUDFLARE_KV_KEY_PREFIX=portfolio:

# Cloudflare R2 (API S3-compatible desde Cloud Run / Node)
# Crea un API Token R2 en R2 > Manage R2 API Tokens (Object Read & Write)
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=your_r2_bucket_name_here
# Opcional: prefijo de objetos si compartes bucket con otro sistema
# R2_OBJECT_KEY_PREFIX=portfolio/
# Opcional: URL publica del bucket (dominio custom o r2.dev) para enlaces directos
# R2_PUBLIC_BASE_URL=https://media.tudominio.com

# Firebase Configuration (if needed)
# PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
# PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
# PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
# PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
# PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
# PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# Firebase Admin SDK (server-side)
# FIREBASE_ADMIN_SDK_KEY=your_firebase_admin_sdk_key_here
