{
  "name": "portfolio-astro-firebase",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "astro": "astro",
    "docker:build": "docker build -t portfolio-astro .",
    "docker:run": "docker run -p 8080:8080 --env-file .env portfolio-astro",
    "deploy:cloudrun": "gcloud run deploy portfolio --source . --region europe-west1 --allow-unauthenticated"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.3",
    "@astrojs/preact": "^4.1.3",
    "astro": "^5.17.1",
    "dotenv": "^17.2.4",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "marked": "^17.0.2",
    "preact": "^10.28.3",
    "preact-router": "^4.1.2"
  }
}
