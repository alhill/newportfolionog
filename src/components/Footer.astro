<style>
  footer {
    height: 100px;
    padding: 0 50px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .footer-content {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: #666;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .separator {
    color: #666;
  }

  .copyright {
    font-weight: 400;
  }

  .email {
    color: #666;
    text-decoration: underline;
    transition: opacity 0.2s;
  }

  .email:hover {
    opacity: 0.7;
  }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .social-icons a {
    color: #ff5faf;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
  }

  .social-icons a:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    footer {
      padding: 0 12px;
      height: auto;
      min-height: 100px;
      padding-top: 20px;
      padding-bottom: 20px;
      justify-content: flex-start;
    }

    .footer-content {
      font-size: 12px;
      gap: 8px;
      justify-content: flex-start;
    }

    .social-icons {
      gap: 10px;
    }

    .social-icons svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
