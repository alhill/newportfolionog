---
import Layout from '../layouts/Layout.astro';
import { getRequestOrigin } from '../lib/request-origin';

// Obtener proyectos (sin filtro de featured hasta que se cree el índice)
let projects: any[] = [];
let error = null;
const origin = getRequestOrigin(Astro.request);

try {
	const limit = 50;
	let page = 1;
	let hasNext = true;

	while (hasNext) {
		const response = await fetch(`${origin}/api/projects?limit=${limit}&page=${page}`);
		const projectsData = await response.json();

		if (!projectsData.success) {
			error = projectsData.error;
			console.error('Error loading projects:', projectsData.error);
			break;
		}

		projects = [...projects, ...(projectsData.data || [])];
		hasNext = Boolean(projectsData.pagination?.hasNext);
		page += 1;
	}
} catch (e) {
	error = (e as Error).message;
  console.error('Error fetching projects:', e);
}
---

<Layout title="Portfolio | Srta. Nognog">
	<main class="portfolio-main">
		<section class="projects-grid">
			{projects.length === 0 ? (
				<p class="empty">No hay proyectos disponibles</p>
			) : (
				projects.map((project: any) => (
					<article class="project-card" data-width={project.width || 1} data-height={project.height || 1}>
						<a href={`/portfolio/${project.slug || project.id}`} style={`background-image: url(${project.thumb})`}>
							<div class="overlay"></div>
							<h2 class="project-title">{project.title}</h2>
							<span class="arrow">→</span>
						</a>
					</article>
				))
			)}
		</section>
	</main>
</Layout>

<style>
	.portfolio-main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
	}

	.hero {
		text-align: center;
		margin-bottom: 4rem;
		padding: 4rem 0;
	}

	.hero h1 {
		font-size: 4rem;
		margin: 0 0 1rem 0;
		font-weight: 700;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.subtitle {
		font-size: 1.5rem;
		color: #666;
		margin: 0;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		grid-auto-rows: 200px;
		grid-auto-flow: dense;
		gap: 20px;
		margin-bottom: 4rem;
	}

	.project-card {
		overflow: hidden;
	}

	.project-card[data-width="1"] {
		grid-column: span 1;
	}

	.project-card[data-width="2"] {
		grid-column: span 2;
	}

	.project-card[data-width="3"] {
		grid-column: span 3;
	}

	.project-card[data-width="4"] {
		grid-column: span 4;
	}

	.project-card[data-width="5"] {
		grid-column: span 5;
	}

	.project-card[data-height="1"] {
		grid-row: span 1;
	}

	.project-card[data-height="2"] {
		grid-row: span 2;
	}

	.project-card a {
		text-decoration: none;
		color: white;
		display: block;
		width: 100%;
		height: 100%;
		background-size: cover;
		background-position: center;
		position: relative;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
	}

	.overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0);
		transition: background 0.3s ease;
		z-index: 1;
	}

	.project-card:hover .overlay {
		background: rgba(0, 0, 0, 0.6);
	}

	.project-title {
		margin: 0;
		font-size: 22px;
		font-weight: 400;
		color: white;
		position: relative;
		z-index: 2;
	}

	.arrow {
		position: absolute;
		bottom: 2rem;
		right: 2rem;
		font-size: 48px;
		line-height: 1;
		opacity: 0;
		transform: translateX(-10px);
		transition: all 0.3s ease;
		z-index: 2;
	}

	.project-card:hover .arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.error-message {
		background: #fff3cd;
		border: 1px solid #ffc107;
		border-radius: 8px;
		padding: 1.5rem;
		margin-bottom: 2rem;
		text-align: center;
	}

	.error-message p {
		margin: 0.5rem 0;
		color: #856404;
	}

	.error-detail {
		font-size: 0.9rem;
		color: #666;
	}

	.empty {
		text-align: center;
		padding: 4rem;
		color: #999;
		font-size: 1.2rem;
		grid-column: 1 / -1;
	}

	@media (max-width: 1024px) {
		.projects-grid {
			grid-template-columns: repeat(4, 1fr);
		}
		
		.project-card[data-width="5"] {
			grid-column: span 4;
		}
	}

	@media (max-width: 900px) {
		.projects-grid {
			grid-template-columns: repeat(3, 1fr);
		}
		
		.project-card[data-width="4"] {
			grid-column: span 3;
		}

		.project-card[data-width="5"] {
			grid-column: span 3;
		}
	}

	@media (max-width: 768px) {
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		
		.project-card[data-width="3"],
		.project-card[data-width="4"],
		.project-card[data-width="5"] {
			grid-column: span 2;
		}
	}

	@media (max-width: 480px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
		
		.project-card[data-width="2"],
		.project-card[data-width="3"],
		.project-card[data-width="4"],
		.project-card[data-width="5"] {
			grid-column: span 1;
		}
		
		.project-card[data-height="1"],
		.project-card[data-height="2"] {
			grid-row: span 1;
		}
	}
</style>
