---
import Layout from '../layouts/Layout.astro';
import AnimatedImages from '../components/AnimatedImages.astro';
import { getRequestOrigin } from '../lib/request-origin';
import bang from '../assets/bang.png'

const origin = getRequestOrigin(Astro.request);

// Obtener datos de la página desde Firebase a través de la API
let pageData: Record<string, any> = {};
try {
  const res = await fetch(`${origin}/api/pages/sobre-mi`);
  const json = await res.json();
  if (json.success) pageData = json.data ?? {};
} catch (_) {}

const title: string = pageData.title ?? 'Srta. Nognog';
const subtitle: string = pageData.subtitle ?? 'Diseñadora gráfica & directora de arte';
const content: string =
  pageData.content ??
  (pageData.bio ? `<p>${String(pageData.bio).replace(/\n\n/g, '</p><p>')}</p>` : null) ??
  '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed euismod, nisl vel ultricies lacinia, nisl nisl aliquam nisl, nec aliquam nisl nisl sit amet nisl.</p><p>Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Vestibulum tortor quam, feugiat vitae, ultricies eget, tempor sit amet, ante.</p><p>Aenean ultricies mi vitae est. Mauris placerat eleifend leo. Quisque sit amet est et sapien ullamcorper pharetra.</p>';
const ctaText: string = pageData.ctaText ?? pageData.linkLabel ?? 'Ver mi trabajo';
const ctaUrl: string = pageData.ctaUrl ?? pageData.linkUrl ?? '/';
---

<Layout title="Sobre mí | Srta. Nognog" description="Presentación personal de Srta. Nognog">
  <main class="sobremi-main">

    <!-- Animación de imágenes -->
    <section class="sobremi-hero">
      <div class="hero-variant hero-variant--wide">
        <AnimatedImages variant="wide" />
      </div>
      <div class="hero-variant hero-variant--contact">
        <AnimatedImages variant="contact" />
      </div>
    </section>

    <!-- Contenido en dos columnas -->
    <section class="sobremi-content">

      <!-- Columna izquierda: título, subtítulo, redes -->
      <aside class="sobremi-sidebar">
        <h1 class="sobremi-title">{title}</h1>
        <p class="sobremi-subtitle">{subtitle}</p>

        <div class="sobremi-socials">
          <a href="https://instagram.com/srta.nognog" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
