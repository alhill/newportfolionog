        </div>
      </aside>

      <!-- Columna derecha: bio + CTA -->
      <div class="sobremi-bio">
        <div class="sobremi-text" set:html={content} />
        <a href={ctaUrl} class="sobremi-cta">{ctaText}</a>
      </div>

    </section>

    <!-- Imagen a ancho completo -->
    <div class="sobremi-fullwidth-image">
      <img src={bang.src} alt="Srta. Nognog" />
    </div>

  </main>
</Layout>

<style>
  .sobremi-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  /* ── Hero animado ── */
  .sobremi-hero {
    margin-bottom: 3rem;
  }

  .hero-variant--wide {
    display: block !important;
  }

  .hero-variant--contact {
    display: none !important;
  }

  .sobremi-hero :global(.animated-images-wrapper--wide .anim-image) {
    object-fit: contain;
  }

  .sobremi-hero :global(.animated-images-wrapper--contact .anim-image) {
    object-fit: contain;
  }

  /* ── Dos columnas ── */
  .sobremi-content {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
    align-items: start;
  }

  .sobremi-content > * {
    min-width: 0;
  }

  /* Columna izquierda */
  .sobremi-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sobremi-title {
    font-size: 2rem;
    font-weight: 500;
    color: #333;
    letter-spacing: -1px;
    line-height: 1.2;
    margin: 0;
  }

  .sobremi-subtitle {
    font-size: 0.9em;
    color: #999;
    font-weight: 300;
    line-height: 1.4;
    margin: 0;
  }

  .sobremi-socials {
    display: grid;
    grid-template-columns: repeat(3, 20px);
    gap: 10px 14px;
    align-items: center;
    justify-content: start;
    margin-top: 0.5rem;
  }

  .sobremi-socials a {
    color: #ff5faf;
    transition: color 0.2s, opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .sobremi-socials a:hover {
    color: #ff3f9f;
    opacity: 0.75;
  }

  /* Columna derecha */
  .sobremi-bio {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    min-width: 0;
  }

  .sobremi-text {
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .sobremi-text,
  .sobremi-text :global(*) {
    font-family: 'Source Sans 3', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
  }

  .sobremi-text :global(p),
  .sobremi-text :global(ul),
  .sobremi-text :global(ol) {
    display: block !important;
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box;
    white-space: normal !important;
    overflow-wrap: anywhere;
    word-break: break-word;
    font-size: 1.1rem;
    font-weight: 300;
    color: #333;
    line-height: 1.7;
    margin: 0 0 1.2rem;
  }

  .sobremi-text :global(span),
  .sobremi-text :global(a),
  .sobremi-text :global(strong),
  .sobremi-text :global(em),
  .sobremi-text :global(b),
  .sobremi-text :global(i) {
    max-width: 100% !important;
    white-space: normal !important;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .sobremi-text :global(strong),
  .sobremi-text :global(b) {
    font-weight: 600;
  }

  .sobremi-text :global(p:last-child),
  .sobremi-text :global(ul:last-child),
  .sobremi-text :global(ol:last-child) {
    margin-bottom: 0;
  }

  .sobremi-text :global(a) {
    color: #ff99cc;
    font-weight: 600;
    text-decoration: underline;
  }

  /* Botón CTA */
  .sobremi-cta {
    display: inline-block;
    padding: 0.875rem 2rem;
    color: white;
    background-color: #03deff;
    border-radius: 4px;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: border-color 0.3s, color 0.3s;
    width: fit-content;
  }

  .sobremi-cta:hover {
    border-color: #777;
    color: #333;
  }

  /* Imagen full-width */
  .sobremi-fullwidth-image {
    width: 100%;
  }

  .sobremi-fullwidth-image img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  /* ── Responsive ── */
  @media (max-width: 699px) {
    .hero-variant--wide {
      display: none !important;
    }

    .hero-variant--contact {
      display: block !important;
    }

    .sobremi-hero {
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 700px) {
    .sobremi-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
